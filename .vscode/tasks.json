{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["-B", "build", "-DCMAKE_BUILD_TYPE=Debug"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake Configure (Release)",
            "type": "shell",
            "command": "cmake",
            "args": ["-B", "build", "-DCMAKE_BUILD_TYPE=Release"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--config", "Debug"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"],
            "dependsOn": "CMake Configure (Debug)"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--config", "Release"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": ["$msCompile"],
            "dependsOn": "CMake Configure (Release)"
        },
        {
            "label": "Transpile Current .tlua",
            "type": "shell",
            "command": "${workspaceFolder}/build/Debug/tluac.exe",
            "args": ["${file}"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": "Build Debug"
        },
        {
            "label": "Transpile demo.tlua",
            "type": "shell",
            "command": "${workspaceFolder}/build/Debug/tluac.exe",
            "args": ["examples/demo.tlua"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": "Build Debug"
        },
        {
            "label": "npm: compile - vscode-tlua",
            "type": "npm",
            "script": "compile",
            "path": "vscode-tlua",
            "problemMatcher": ["$tsc"],
            "group": "build"
        }
    ]
}
